# Runtime outputs — skills write these to the session cwd, never commit them
artifacts/
*.log

# Playwright MCP scratch (page snapshots/console logs written during browser runs)
.playwright-mcp/

# Local source material distilled into skills (kept for provenance, not shipped)
.refs/

# Python — caches/bytecode from running the bundled scripts & tests
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.venv/
venv/

# OS / editor cruft
.DS_Store
*.swp
.idea/
.vscode/

# Local secrets never live here (they're in ~/.claude/.env) — belt and braces:
.env
*.env

docs/