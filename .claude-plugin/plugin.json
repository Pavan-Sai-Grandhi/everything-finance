{
  "name": "everything-finance",
  "version": "0.6.0",
  "description": "Personal India-focused financial intelligence: strategy-driven trade finding on the Nifty 500, multi-agent deep stock analysis, DCF valuation, sector rotation, mutual fund research, insurance gap analysis, budget tracking, exchange-filings monitoring, reference-article-driven strategy design, and live trade tracking against your broker (Zerodha/Upstox).",
  "author": {
    "name": "Pavan Sai Grandhi"
  },
  "keywords": [
    "finance",
    "india",
    "swing-trading",
    "find-trade",
    "nifty500",
    "mutual-funds",
    "budgeting",
    "nse",
    "bse",
    "zerodha",
    "upstox",
    "trade-tracker",
    "dcf",
    "valuation",
    "governance"
  ],
  "skills": [
    "./skills/find-trade",
    "./skills/deep-analysis",
    "./skills/fundamental-analysis",
    "./skills/sector-analysis",
    "./skills/mf-research",
    "./skills/insurance-check",
    "./skills/budget-tracker",
    "./skills/filings-watch",
    "./skills/daily-brief",
    "./skills/portfolio-review",
    "./skills/backtest",
    "./skills/strategy-manager",
    "./skills/trade-tracker",
    "./skills/dcf-valuation",
    "./skills/management-quality",
    "./skills/alert-manager"
  ],
  "agents": [
    "./agents/technical-analyst.md",
    "./agents/fundamentals-data.md",
    "./agents/financials-analyst.md",
    "./agents/management-analyst.md",
    "./agents/valuation-analyst.md",
    "./agents/news-sentiment.md",
    "./agents/sector-analyst.md",
    "./agents/bull-researcher.md",
    "./agents/bear-researcher.md",
    "./agents/portfolio-manager.md"
  ],
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "kite": {
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/mcp-bridge.sh",
      "args": ["https://mcp.kite.trade/mcp"]
    },
    "upstox": {
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/mcp-bridge.sh",
      "args": ["https://mcp.upstox.com/mcp"]
    },
    "indmoney": {
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/mcp-bridge.sh",
      "args": ["https://mcp.indmoney.com/mcp"]
    }
  }
}
